<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="800.0" prefWidth="1300.0" style="-fx-background-color:#f4f6f5;"
    xmlns="http://javafx.com/javafx/9" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="Karyawan.DashboardKaryawanController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="30"
            style="-fx-background-color:white; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),10,0,0,2);">
            <padding>
                <Insets bottom="16" left="30" right="30" top="16" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <StackPane prefHeight="30" prefWidth="30"
                    style="-fx-background-color: #6495ed; -fx-background-radius: 20;">
                    <Label style="-fx-font-size:14;" text="🧺" />
                </StackPane>
                <Label style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#111827;"
                    text="SILAU" />
            </HBox>

            <HBox spacing="6">
                <Button fx:id="btnDashboard" onAction="#showDashboard"
                    style="-fx-background-color: #6495ed; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 16; -fx-cursor: hand;"
                    text="Dashboard" />
                <Button fx:id="btnPesanan" onAction="#showPesanan"
                    style="-fx-background-color:transparent; -fx-text-fill:#6b7280; -fx-font-size:13;                                -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                    text="Pesanan" />
                <Button fx:id="btnTransaksi" onAction="#showTransaksi"
                    style="-fx-background-color:transparent; -fx-text-fill:#6b7280; -fx-font-size:13;                                -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                    text="Transaksi" />
                <Button fx:id="btnKomplain" onAction="#showKomplain"
                    style="-fx-background-color:transparent; -fx-text-fill:#6b7280; -fx-font-size:13;                                -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                    text="Komplain" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <StackPane>
                <Circle fill="#e5e7eb" radius="18" />
                <Label fx:id="lblInisial" style="-fx-text-fill:#374151; -fx-font-weight:bold;"
                    text="A" />
            </StackPane>

            <Button fx:id="btnKeluar" onAction="#keluar"
                style="-fx-background-color:#fee2e2; -fx-text-fill:#dc2626; -fx-font-size:12;                            -fx-font-weight:bold; -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                text="Keluar" />

        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">
            <content>
                <VBox spacing="24" style="-fx-background-color:#f4f6f5;">
                    <padding>
                        <Insets bottom="28" left="35" right="35" top="28" />
                    </padding>

                    <!-- Header -->
                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="2">
                            <HBox alignment="BASELINE_LEFT" spacing="6">
                                <Label
                                    style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"
                                    text="Selamat Datang," />
                                <Label fx:id="lblNamaUser"
                                    style="-fx-font-size:24; -fx-text-fill:#9ca3af;"
                                    text="Nama Karyawan" />
                            </HBox>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button
                            style="-fx-background-color: #6495ed; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand;"
                            text="+ Tambah Pesanan" />
                    </HBox>

                    <!-- Row 1: Stat Cards + Chart -->
                    <HBox spacing="20">

                        <!-- Card kiri -->
                        <VBox prefWidth="280" spacing="14"
                            style="-fx-background-color:white; -fx-background-radius:15;                                      -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">
                            <padding>
                                <Insets bottom="18" left="18" right="18" top="18" />
                            </padding>

                            <Label style="-fx-font-size:12; -fx-text-fill:#6b7280;"
                                text="Pesanan Menunggu" />

                            <VBox spacing="6"
                                style="-fx-background-color: #6495ed; -fx-background-radius: 12;">
                                <padding>
                                    <Insets bottom="16" left="16" right="16" top="16" />
                                </padding>
                                <Label style="-fx-text-fill:#dbeafe; -fx-font-size:11;"
                                    text="Total Pesanan" />
                                <Label fx:id="lblMenunggu"
                                    style="-fx-text-fill:white; -fx-font-size:26; -fx-font-weight:bold;"
                                    text="—" />
                            </VBox>

                            <Label style="-fx-font-size:12; -fx-text-fill:#6b7280;"
                                text="Sedang Dicuci" />
                            <HBox alignment="CENTER_LEFT">
                                <Label fx:id="lblDicuci"
                                    style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#111827;"
                                    text="—" />
                            </HBox>
                        </VBox>

                        <!-- Chart -->
                        <VBox spacing="10"
                            style="-fx-background-color:white; -fx-background-radius:15;                                      -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);"
                            HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="10" left="18" right="18" top="18" />
                            </padding>

                            <HBox alignment="CENTER_LEFT">
                                <Label
                                    style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#111827;"
                                    text="Grafik Pesanan" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ToggleButton selected="true"
                                    style="-fx-background-color: #6495ed; -fx-text-fill: white; -fx-background-radius: 15; -fx-font-size: 11;"
                                    text="Mingguan" />
                            </HBox>

                            <BarChart fx:id="chartPesanan" legendVisible="false" prefHeight="230"
                                style="-fx-background-color:transparent;">
                                <xAxis>
                                    <CategoryAxis fx:id="chartXAxis" side="BOTTOM" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis fx:id="chartYAxis" side="LEFT" />
                                </yAxis>
                            </BarChart>
                        </VBox>

                        <!-- Card kanan -->
                        <VBox prefWidth="260" spacing="14"
                            style="-fx-background-color:white; -fx-background-radius:15;                                      -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">
                            <padding>
                                <Insets bottom="18" left="18" right="18" top="18" />
                            </padding>

                            <Label style="-fx-font-size:12; -fx-text-fill:#6b7280;"
                                text="Total Pesanan Saya" />
                            <Label fx:id="lblTotalSaya"
                                style="-fx-font-size:30; -fx-font-weight:bold; -fx-text-fill:#111827;"
                                text="—" />

                            <Separator />

                            <Label style="-fx-font-size:12; -fx-text-fill:#6b7280;"
                                text="Selesai Hari Ini" />
                            <Label fx:id="lblSelesai"
                                style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#6495ed;"
                                text="—" />
                        </VBox>

                    </HBox>

                    <!-- Tabel Pesanan -->
                    <VBox spacing="0"
                        style="-fx-background-color:white; -fx-background-radius:15;                                  -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">

                        <HBox alignment="CENTER_LEFT">
                            <Label
                                style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#111827;"
                                text="Pesanan Aktif">
                                <padding>
                                    <Insets bottom="14" left="20" right="20" top="18" />
                                </padding>
                            </Label>
                        </HBox>

                        <Separator />

                        <TableView fx:id="tabelPesanan" prefHeight="260" prefWidth="1135.0"
                            style="-fx-background-color:transparent;">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                                <TableColumn fx:id="colPelanggan" prefWidth="220" text="PELANGGAN" />
                                <TableColumn fx:id="colLayanan" prefWidth="220" text="LAYANAN" />
                                <TableColumn fx:id="colBerat" prefWidth="120" text="BERAT" />
                                <TableColumn fx:id="colBiaya" prefWidth="150" text="BIAYA" />
                                <TableColumn fx:id="colStatus" prefWidth="194.66656494140625"
                                    text="STATUS" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>