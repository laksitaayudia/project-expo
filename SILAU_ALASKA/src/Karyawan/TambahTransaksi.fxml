<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/9"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Karyawan.TambahTransaksiController"
      spacing="18"
      alignment="TOP_CENTER"
      style="-fx-background-color:#f4f6f5;">

    <padding>
        <Insets top="25" right="35" bottom="25" left="35"/>
    </padding>

    <Label text="Tambah Transaksi"
           style="-fx-font-size:24;
                  -fx-font-weight:bold;
                  -fx-text-fill:#111827;"/>

    <VBox spacing="12"
          maxWidth="420"
          style="-fx-background-color:white;
                 -fx-background-radius:15;
                 -fx-padding:20;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,3);">

        <Label text="ID Pesanan"/>

        <ComboBox fx:id="cbPesanan"/>

        <Label text="Nama Pelanggan"/>

        <TextField fx:id="txtPelanggan"
                   editable="false"/>

        <Label text="Total"/>

        <TextField fx:id="txtTotal"
                   editable="false"/>

        <Label text="Status Pembayaran"/>

        <ComboBox fx:id="cbStatus"/>

        <Label text="Metode Pembayaran"/>

        <ComboBox fx:id="cbMetode"/>

        <Label text="Tanggal Bayar"/>

        <DatePicker fx:id="dpTanggal"/>

        <HBox spacing="12"
              alignment="CENTER_RIGHT">

            <Button text="Batal"
                    onAction="#batal"
                    style="-fx-background-color:#9ca3af;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;
                           -fx-background-radius:8;"/>

            <Button text="Simpan"
                    onAction="#simpan"
                    style="-fx-background-color:#6495ed;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;
                           -fx-background-radius:8;"/>

        </HBox>

    </VBox>

</VBox>