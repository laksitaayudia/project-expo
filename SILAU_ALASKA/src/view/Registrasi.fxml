<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0"
    prefWidth="800.0"
    xmlns="http://javafx.com/javafx/9"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.RegistrasiController">

    <children>

        <Pane prefHeight="500.0"
            prefWidth="800.0"
            style="-fx-background-color:#E3F2FD;">

            <children>

                <VBox alignment="CENTER"
                    layoutX="220"
                    layoutY="35"
                    prefHeight="430"
                    prefWidth="360"
                    spacing="12"
                    style="-fx-background-color:white;
                             -fx-background-radius:15;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),15,0,0,5);">

                    <padding>
                        <Insets top="25"
                            right="30"
                            bottom="25"
                            left="30" />
                    </padding>

                    <Label text="Daftar Akun">
                        <font>
                            <Font size="24" />
                        </font>
                    </Label>

                    <Label text="Pendaftaran Pelanggan" />

                    <Separator />

                    <TextField fx:id="txtNama"
                        promptText="Nama Lengkap"
                        prefWidth="285" />

                    <TextField fx:id="txtUsername"
                        promptText="Username"
                        prefWidth="285" />

                    <PasswordField fx:id="txtPassword"
                        promptText="Password"
                        prefWidth="280" />

                    <PasswordField fx:id="txtKonfirmasi"
                        promptText="Konfirmasi Password"
                        prefWidth="280" />

                    <Button text="DAFTAR"
                        prefWidth="280"
                        prefHeight="40"
                        style="-fx-background-color:#2196F3;
                                   -fx-text-fill:white;
                                   -fx-font-size:15;"
                        onAction="#daftar" />

                    <Hyperlink text="Sudah punya akun? Login disini"
                        onAction="#kembaliLogin" />

                </VBox>

            </children>

        </Pane>

    </children>

</AnchorPane>