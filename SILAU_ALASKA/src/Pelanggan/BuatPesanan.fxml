<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Pelanggan.BuatPesananController"
            fitToWidth="true"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">
    <content>
        <VBox spacing="20" style="-fx-background-color:#f4f6f5;">
            <padding><Insets top="28" right="35" bottom="28" left="35"/></padding>

            <VBox spacing="4">
                <Label text="Buat Pesanan Baru" style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                <Label text="Isi formulir pesanan laundry" style="-fx-font-size:12; -fx-text-fill:#9ca3af;"/>
            </VBox>

            <VBox spacing="20" maxWidth="650"
                  style="-fx-background-color:white; -fx-background-radius:15;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                <VBox spacing="8">
                    <Label text="Jenis Layanan" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                    <HBox spacing="16">
                        <Button fx:id="btnReguler" onAction="#selectReguler" prefWidth="280" prefHeight="70"
                                style="-fx-background-color:#f8fafc; -fx-border-color:#1e5af6; -fx-border-width:2; -fx-border-radius:10; -fx-background-radius:10; -fx-cursor:hand;"
                                alignment="CENTER">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label fx:id="lblRegulerTitle" text="Reguler 🌾" style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#1e5af6;"/>
                                    <Label fx:id="lblRegulerSub" text="Rp 10.000/kg" style="-fx-font-size:11; -fx-text-fill:#1e5af6;"/>
                                </VBox>
                            </graphic>
                        </Button>
                        <Button fx:id="btnEkspres" onAction="#selectEkspres" prefWidth="280" prefHeight="70"
                                style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:10; -fx-background-radius:10; -fx-cursor:hand;"
                                alignment="CENTER">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label fx:id="lblEkspresTitle" text="Ekspres ⚡" style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#475569;"/>
                                    <Label fx:id="lblEkspresSub" text="Rp 15.000/kg" style="-fx-font-size:11; -fx-text-fill:#64748b;"/>
                                </VBox>
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>

                <VBox spacing="8">
                    <Label text="Pilih Waktu Proses" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                    <HBox spacing="12">
                        <Button fx:id="btnPagi" text="🌅 Pagi" onAction="#selectPagi" prefWidth="180" prefHeight="38"
                                style="-fx-background-color:#f8fafc; -fx-border-color:#1e5af6; -fx-border-width:2; -fx-border-radius:8; -fx-background-radius:8; -fx-font-weight:bold; -fx-text-fill:#1e5af6; -fx-cursor:hand;"/>
                        <Button fx:id="btnSiang" text="☀️ Siang" onAction="#selectSiang" prefWidth="180" prefHeight="38"
                                style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:8; -fx-background-radius:8; -fx-text-fill:#475569; -fx-cursor:hand;"/>
                        <Button fx:id="btnSore" text="🌆 Sore" onAction="#selectSore" prefWidth="180" prefHeight="38"
                                style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:8; -fx-background-radius:8; -fx-text-fill:#475569; -fx-cursor:hand;"/>
                    </HBox>
                </VBox>

                <VBox spacing="6">
                    <Label text="Berat Cucian (gram)" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                    <TextField fx:id="txtBeratGram" promptText="Contoh: 3500 (3.5 kg)"
                               style="-fx-background-radius:8; -fx-border-radius:8; -fx-border-color:#e2e8f0; -fx-padding:10;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Catatan (opsional)" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                    <TextField fx:id="txtCatatan" promptText="Ada baju putih, jangan campur..."
                               style="-fx-background-radius:8; -fx-border-radius:8; -fx-border-color:#e2e8f0; -fx-padding:10;"/>
                </VBox>

                <Button text="Buat Pesanan" onAction="#submitPesanan" maxWidth="Infinity" prefHeight="44"
                        style="-fx-background-color:#1e5af6; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14; -fx-background-radius:8; -fx-cursor:hand;"/>

            </VBox>

        </VBox>
    </content>
</ScrollPane>
