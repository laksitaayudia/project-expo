<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Owner.PengeluaranController"
            fitToWidth="true"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">

    <content>
        <VBox spacing="20" style="-fx-background-color:#f4f6f5;">
            <padding>
                <Insets top="28" right="35" bottom="28" left="35"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Pengeluaran Laundry"
                           style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <Label text="Catat pengeluaran operasional secara terperinci"
                           style="-fx-font-size:13; -fx-text-fill:#6b7280;"/>
                </VBox>
            </HBox>

            <HBox spacing="24" alignment="TOP_LEFT">
                <VBox spacing="16" prefWidth="380" minWidth="380"
                      style="-fx-background-color:white; -fx-background-radius:15;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3); -fx-padding:20;">

                    <Label text="Catat Pengeluaran Baru"
                           style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#111827;"/>

                    <Separator/>

                    <VBox spacing="6">
                        <Label text="Kategori" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <ComboBox fx:id="cbKategori" prefWidth="380"
                                  style="-fx-background-radius:6; -fx-padding:4; -fx-border-color:#d1d5db; -fx-border-radius:6; -fx-background-color:white;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Bahan Baku" />
                                    <String fx:value="Operasional" />
                                    <String fx:value="Gaji Karyawan" />
                                    <String fx:value="Lain-lain" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Jumlah Pengeluaran (Rp)" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <TextField fx:id="txtJumlah" promptText="Contoh: 150000"
                                   style="-fx-background-radius:6; -fx-padding:8; -fx-border-color:#d1d5db; -fx-border-radius:6; -fx-background-color:white;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Keterangan" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <TextField fx:id="txtKeterangan" promptText="Contoh: Beli sabun cair 2 jerigen"
                                   style="-fx-background-radius:6; -fx-padding:8; -fx-border-color:#d1d5db; -fx-border-radius:6; -fx-background-color:white;"/>
                    </VBox>

                    <Button text="Catat Pengeluaran" onAction="#tambahPengeluaran" prefWidth="380"
                            style="-fx-background-color:#6495ed; -fx-text-fill:white; -fx-font-size:13;
                                   -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:10; -fx-cursor:hand;"/>
                </VBox>

                <VBox spacing="0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:15;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">

                    <Label text="Log Pengeluaran Laundry"
                           style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#111827;">
                        <padding>
                            <Insets top="18" right="20" bottom="14" left="20"/>
                        </padding>
                    </Label>

                    <Separator/>

                    <TableView fx:id="tabelPengeluaran"
                               prefHeight="430"
                               style="-fx-background-color:transparent;">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colTanggal" text="TANGGAL" prefWidth="120"/>
                            <TableColumn fx:id="colKategori" text="KATEGORI" prefWidth="140"/>
                            <TableColumn fx:id="colJumlah" text="JUMLAH" prefWidth="130"/>
                            <TableColumn fx:id="colKeterangan" text="KETERANGAN" prefWidth="250"/>
                            <TableColumn fx:id="colAksi" text="AKSI" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
