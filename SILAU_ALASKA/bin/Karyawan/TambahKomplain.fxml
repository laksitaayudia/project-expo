<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="12" prefWidth="380"
    style="-fx-background-color:white;"
    xmlns="http://javafx.com/javafx/9" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="Karyawan.TambahKomplainController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25" />
    </padding>

    <Label text="Catat Komplain Baru">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <Label text="Isi detail komplain dari pelanggan"
        style="-fx-text-fill:#6b7280; -fx-font-size:11;" />

    <Separator />

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="ID Pesanan"
            style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;" />
        <TextField fx:id="txtIdPesanan" promptText="Contoh: PSN001"
            style="-fx-background-radius:8; -fx-border-radius:8; -fx-border-color:#e2e8f0; -fx-padding:8;" />
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="Jenis Komplain"
            style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;" />
        <ComboBox fx:id="cbJenis" prefWidth="330" editable="true">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Baju tertukar" />
                    <String fx:value="Baju rusak/luntur" />
                    <String fx:value="Baju hilang" />
                    <String fx:value="Hasil cuci kurang bersih" />
                    <String fx:value="Pesanan terlambat" />
                    <String fx:value="Lainnya" />
                </FXCollections>
            </items>
        </ComboBox>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="Deskripsi"
            style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;" />
        <TextArea fx:id="txtDeskripsi" promptText="Ceritakan detail komplainnya..." prefRowCount="3"
            wrapText="true"
            style="-fx-background-radius:8; -fx-border-radius:8; -fx-border-color:#e2e8f0;" />
    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Batal" onAction="#batal" prefWidth="160" prefHeight="38"
            style="-fx-background-color:#f1f5f9; -fx-text-fill:#374151; -fx-font-size:13;
                       -fx-background-radius:8; -fx-cursor:hand;" />
        <Button text="Simpan" onAction="#simpan" prefWidth="160" prefHeight="38"
            style="-fx-background-color:#6495ed; -fx-text-fill:white; -fx-font-size:13;
                       -fx-font-weight:bold; -fx-background-radius:8; -fx-cursor:hand;" />
    </HBox>

</VBox>