<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Karyawan.TransaksiController"
            fitToWidth="true"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">

    <content>

        <VBox spacing="20"
              style="-fx-background-color:#f4f6f5;">

            <padding>
                <Insets top="28"
                        right="35"
                        bottom="28"
                        left="35"/>
            </padding>


            <Label text="Manajemen Transaksi"
                   style="-fx-font-size:24;
                          -fx-font-weight:bold;
                          -fx-text-fill:#111827;"/>
            <VBox spacing="0"
                  style="-fx-background-color:white;
                         -fx-background-radius:15;
                         -fx-effect:dropshadow(gaussian,
                         rgba(0,0,0,0.05),
                         12,0,0,3);">

                <Label text="Semua Transaksi"
                       style="-fx-font-size:15;
                              -fx-font-weight:bold;
                              -fx-text-fill:#111827;">

                    <padding>
                        <Insets top="18"
                                right="20"
                                bottom="14"
                                left="20"/>
                    </padding>

                </Label>

                <Separator/>

                <TableView fx:id="tabelTransaksi"
                           prefHeight="500"
                           style="-fx-background-color:transparent;">

                    <columns>

                        <TableColumn fx:id="colId"
                                     text="ID"
                                     prefWidth="70"/>

                        <TableColumn fx:id="colPesanan"
                                     text="PESANAN"
                                     prefWidth="90"/>

                        <TableColumn fx:id="colPelanggan"
                                     text="PELANGGAN"
                                     prefWidth="180"/>

                        <TableColumn fx:id="colTotal"
                                     text="TOTAL"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colStatus"
                                     text="STATUS"
                                     prefWidth="140"/>

                        <TableColumn fx:id="colMetode"
                                     text="METODE"
                                     prefWidth="140"/>

                        <TableColumn fx:id="colTanggal"
                                     text="TANGGAL"
                                     prefWidth="140"/>

                        <TableColumn fx:id="colAksi"
                                     text="AKSI"
                                     prefWidth="160"/>

                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                </TableView>

            </VBox>

        </VBox>

    </content>

</ScrollPane>