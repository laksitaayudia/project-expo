<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Owner.KelolaPromoController"
            fitToWidth="true"
            fitToHeight="false"
            hbarPolicy="AS_NEEDED"
            vbarPolicy="AS_NEEDED"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">

    <content>
        <VBox spacing="20" style="-fx-background-color:#f4f6f5;">
            <padding>
                <Insets top="28" right="35" bottom="28" left="35"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Kelola Promo"
                           style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <Label text="Atur diskon dan penawaran khusus untuk pelanggan"
                           style="-fx-font-size:13; -fx-text-fill:#6b7280;"/>
                </VBox>
            </HBox>

            <ScrollPane fitToHeight="true"
                        hbarPolicy="AS_NEEDED"
                        vbarPolicy="NEVER"
                        style="-fx-background:transparent; -fx-background-color:transparent; -fx-padding:0;">
                <content>
            <HBox spacing="24" alignment="TOP_LEFT">
                <VBox spacing="16" prefWidth="380" minWidth="380"
                      style="-fx-background-color:white; -fx-background-radius:15;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3); -fx-padding:20;">
                    
                    <Label fx:id="lblFormTitle" text="Tambah Promo Baru"
                           style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    
                    <Separator/>

                    <VBox spacing="6">
                        <Label text="Kode Promo" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <TextField fx:id="txtKode" promptText="Contoh: HEMAT10"
                                   style="-fx-background-radius:6; -fx-padding:8; -fx-border-color:#d1d5db; -fx-border-radius:6; -fx-background-color:white;"/>
                    </VBox>

                    <HBox spacing="10">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Diskon" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                            <TextField fx:id="txtDiskon" promptText="Contoh: 10 atau 5000"
                                       style="-fx-background-radius:6; -fx-padding:8; -fx-border-color:#d1d5db; -fx-border-radius:6; -fx-background-color:white;"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Tipe" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                            <ComboBox fx:id="cbTipe" prefWidth="150"
                                      style="-fx-background-radius:6; -fx-padding:4; -fx-border-color:#d1d5db; -fx-border-radius:6; -fx-background-color:white;">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Persentase" />
                                        <String fx:value="Nominal" />
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="Minimal Belanja (Rp)" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <TextField fx:id="txtMinBelanja" promptText="Contoh: 30000"
                                   style="-fx-background-radius:6; -fx-padding:8; -fx-border-color:#d1d5db; -fx-border-radius:6; -fx-background-color:white;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Status" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <ComboBox fx:id="cbStatus" prefWidth="380"
                                  style="-fx-background-radius:6; -fx-padding:4; -fx-border-color:#d1d5db; -fx-border-radius:6; -fx-background-color:white;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Aktif" />
                                    <String fx:value="Non-Aktif" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </VBox>

                    <Button fx:id="btnBatal" text="Batal Edit" onAction="#batalEdit" prefWidth="380"
                            visible="false" managed="false"
                            style="-fx-background-color:#fee2e2; -fx-text-fill:#dc2626; -fx-font-size:13;
                                   -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:10; -fx-cursor:hand;"/>
                    <Button fx:id="btnSimpan" text="Simpan Promo" onAction="#tambahPromo" prefWidth="380"
                            style="-fx-background-color:#6495ed; -fx-text-fill:white; -fx-font-size:13;
                                   -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:10; -fx-cursor:hand;"/>
                </VBox>

                <VBox spacing="0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:15;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">

                    <Label text="Daftar Promo Laundry"
                           style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#111827;">
                        <padding>
                            <Insets top="18" right="20" bottom="14" left="20"/>
                        </padding>
                    </Label>

                    <Separator/>

                    <TableView fx:id="tabelPromo"
                               prefHeight="430"
                               style="-fx-background-color:transparent;">
                        <columns>
                            <TableColumn fx:id="colKode" text="KODE PROMO" prefWidth="120"/>
                            <TableColumn fx:id="colDiskon" text="DISKON" prefWidth="120"/>
                            <TableColumn fx:id="colTipe" text="TIPE" prefWidth="120"/>
                            <TableColumn fx:id="colMinBelanja" text="MIN. BELANJA" prefWidth="150"/>
                            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="120"/>
                            <TableColumn fx:id="colAksi" text="AKSI" prefWidth="160"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </HBox>
                </content>
            </ScrollPane>
        </VBox>
    </content>
</ScrollPane>
