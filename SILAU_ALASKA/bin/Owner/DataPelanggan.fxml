<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Owner.DataPelangganController"
            fitToWidth="true"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">

    <content>
        <VBox spacing="20" style="-fx-background-color:#f4f6f5;">
            <padding>
                <Insets top="28" right="35" bottom="28" left="35"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Data Pelanggan"
                           style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <Label text="Daftar pelanggan terdaftar dari formulir registrasi"
                           style="-fx-font-size:13; -fx-text-fill:#6b7280;"/>
                </VBox>
            </HBox>

            <!-- Table Card -->
            <VBox spacing="0"
                  style="-fx-background-color:white; -fx-background-radius:15;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">

                <Label text="Pelanggan Terdaftar"
                       style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#111827;">
                    <padding>
                        <Insets top="18" right="20" bottom="14" left="20"/>
                    </padding>
                </Label>

                <Separator/>

                <TableView fx:id="tabelPelanggan"
                           prefHeight="500"
                           style="-fx-background-color:transparent;">
                    <columns>
                        <TableColumn fx:id="colNama" text="NAMA LENGKAP" prefWidth="180"/>
                        <TableColumn fx:id="colTelepon" text="TELEPON" prefWidth="140"/>
                        <TableColumn fx:id="colEmail" text="EMAIL" prefWidth="180"/>
                        <TableColumn fx:id="colAlamat" text="ALAMAT" prefWidth="250"/>
                        <TableColumn fx:id="colUsername" text="USERNAME" prefWidth="140"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
