<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="800.0" prefWidth="1300.0" style="-fx-background-color:#f4f6f5;"
            xmlns="http://javafx.com/javafx/9" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Owner.DashboardOwnerController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="24"
              style="-fx-background-color:white; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),10,0,0,2);">
            <padding>
                <Insets bottom="16" left="30" right="30" top="16" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <StackPane prefHeight="30" prefWidth="30">
                    <ImageView fitHeight="30.0" fitWidth="30.0" preserveRatio="true">
                        <image>
                            <Image url="@/Logo/logo.png" />
                        </image>
                        <clip>
                            <Circle centerX="15" centerY="15" radius="15" />
                        </clip>
                    </ImageView>
                </StackPane>
                <Label style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#111827;"
                       text="SILAU" />
            </HBox>

            <HBox spacing="6">
                <Button fx:id="btnDashboard" onAction="#showDashboard"
                        style="-fx-background-color: #6495ed; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 16; -fx-cursor: hand;"
                        text="Dashboard" />
                <Button fx:id="btnRekap" onAction="#showRekap"
                        style="-fx-background-color:transparent; -fx-text-fill:#6b7280; -fx-font-size:13; -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                        text="Rekap Pendapatan" />
                <Button fx:id="btnPromo" onAction="#showPromo"
                        style="-fx-background-color:transparent; -fx-text-fill:#6b7280; -fx-font-size:13; -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                        text="Kelola Promo" />
                <Button fx:id="btnPengeluaran" onAction="#showPengeluaran"
                        style="-fx-background-color:transparent; -fx-text-fill:#6b7280; -fx-font-size:13; -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                        text="Pengeluaran" />
                <Button fx:id="btnPelanggan" onAction="#showPelanggan"
                        style="-fx-background-color:transparent; -fx-text-fill:#6b7280; -fx-font-size:13; -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                        text="Data Pelanggan" />
                <Button fx:id="btnKaryawan" onAction="#showKaryawan"
                        style="-fx-background-color:transparent; -fx-text-fill:#6b7280; -fx-font-size:13; -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                        text="Data Karyawan" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <StackPane>
                <Circle fill="#e5e7eb" radius="18" />
                <Label fx:id="lblInisial" style="-fx-text-fill:#374151; -fx-font-weight:bold;"
                       text="O" />
            </StackPane>

            <Button fx:id="btnKeluar" onAction="#keluar"
                    style="-fx-background-color:#fee2e2; -fx-text-fill:#dc2626; -fx-font-size:12;                            -fx-font-weight:bold; -fx-background-radius:20; -fx-padding:8 16; -fx-cursor:hand;"
                    text="Keluar" />

        </HBox>
    </top>

    <center>
        <StackPane style="-fx-background-color:#f4f6f5;">

            <ScrollPane fx:id="scrollDashboard" fitToWidth="true" visible="true" managed="true"
                        style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">
                <content>
                    <VBox spacing="24" style="-fx-background-color:#f4f6f5;">
                        <padding><Insets top="28" right="35" bottom="28" left="35"/></padding>

                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2">
                                <HBox spacing="6" alignment="BASELINE_LEFT">
                                    <Label text="Selamat Datang," style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                                    <Label fx:id="lblNamaUser" text="Nama Owner" style="-fx-font-size:24; -fx-text-fill:#9ca3af;"/>
                                </HBox>
                            </VBox>
                        </HBox>

                        <HBox spacing="20">
                            <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="250"
                                  style="-fx-background-color:white; -fx-background-radius:15;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3); -fx-padding:18;">
                                <Label text="Total Pendapatan" style="-fx-font-size:12; -fx-text-fill:#6b7280; -fx-font-weight:bold;"/>
                                <Label fx:id="lblPendapatan" text="Rp 0" style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#10b981;"/>
                                <Label text="Transaksi berstatus lunas" style="-fx-font-size:10; -fx-text-fill:#9ca3af;"/>
                            </VBox>

                            <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="250"
                                  style="-fx-background-color:white; -fx-background-radius:15;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3); -fx-padding:18;">
                                <Label text="Total Pengeluaran" style="-fx-font-size:12; -fx-text-fill:#6b7280; -fx-font-weight:bold;"/>
                                <Label fx:id="lblPengeluaran" text="Rp 0" style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#ef4444;"/>
                                <Label text="Biaya operasional laundry" style="-fx-font-size:10; -fx-text-fill:#9ca3af;"/>
                            </VBox>

                            <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="250"
                                  style="-fx-background-color:white; -fx-background-radius:15;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3); -fx-padding:18;">
                                <Label text="Pelanggan Terdaftar" style="-fx-font-size:12; -fx-text-fill:#6b7280; -fx-font-weight:bold;"/>
                                <Label fx:id="lblPelangganCount" text="0" style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#3b82f6;"/>
                                <Label text="Pendaftaran baru via aplikasi" style="-fx-font-size:10; -fx-text-fill:#9ca3af;"/>
                            </VBox>

                            <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="250"
                                  style="-fx-background-color:white; -fx-background-radius:15;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3); -fx-padding:18;">
                                <Label text="Promo Aktif" style="-fx-font-size:12; -fx-text-fill:#6b7280; -fx-font-weight:bold;"/>
                                <Label fx:id="lblPromoCount" text="0" style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#f59e0b;"/>
                                <Label text="Kode voucher diskon aktif" style="-fx-font-size:10; -fx-text-fill:#9ca3af;"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="10"
                              style="-fx-background-color:white; -fx-background-radius:15;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3); -fx-padding:18;">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Analisis Keuangan Laundry" style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <ToggleButton text="Bulanan" selected="true"
                                              style="-fx-background-color:#6495ed; -fx-text-fill:white; -fx-background-radius:15; -fx-font-size:11;"/>
                            </HBox>
                            <BarChart fx:id="chartKeuangan" prefHeight="260" legendVisible="true"
                                      style="-fx-background-color:transparent;">
                                <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                                <yAxis><NumberAxis side="LEFT"/></yAxis>
                            </BarChart>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <fx:include fx:id="rekapPendapatan" source="RekapPendapatan.fxml" visible="false" managed="false"/>
            <fx:include fx:id="kelolaPromo" source="KelolaPromo.fxml" visible="false" managed="false"/>
            <fx:include fx:id="pengeluaran" source="Pengeluaran.fxml" visible="false" managed="false"/>
            <fx:include fx:id="dataPelanggan" source="DataPelanggan.fxml" visible="false" managed="false"/>
            <fx:include fx:id="daftarKaryawan" source="DaftarKaryawan.fxml" visible="false" managed="false"/>

        </StackPane>
    </center>

</BorderPane>