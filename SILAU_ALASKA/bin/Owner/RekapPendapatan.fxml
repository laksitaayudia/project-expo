<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Owner.RekapPendapatanController"
            fitToWidth="true"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">

    <content>
        <VBox spacing="20" style="-fx-background-color:#f4f6f5;">
            <padding>
                <Insets top="28" right="35" bottom="28" left="35"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Rekap Pendapatan"
                           style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <Label text="Laporan keuangan real-time laundry"
                           style="-fx-font-size:13; -fx-text-fill:#6b7280;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Total Card -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-padding:10 20;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.03),8,0,0,2);">
                    <VBox>
                        <Label text="TOTAL PENDAPATAN" style="-fx-font-size:10; -fx-text-fill:#9ca3af; -fx-font-weight:bold;"/>
                        <Label fx:id="lblTotalPendapatan" text="Rp 0"
                               style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#10b981;"/>
                    </VBox>
                </HBox>
            </HBox>

            <!-- Table Card -->
            <VBox spacing="0"
                  style="-fx-background-color:white; -fx-background-radius:15;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">

                <Label text="Histori Transaksi Masuk"
                       style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#111827;">
                    <padding>
                        <Insets top="18" right="20" bottom="14" left="20"/>
                    </padding>
                </Label>

                <Separator/>

                <TableView fx:id="tabelTransaksi"
                           prefHeight="500"
                           style="-fx-background-color:transparent;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID TRANSAKSI" prefWidth="120"/>
                        <TableColumn fx:id="colPesanan" text="ID PESANAN" prefWidth="120"/>
                        <TableColumn fx:id="colPelanggan" text="PELANGGAN" prefWidth="200"/>
                        <TableColumn fx:id="colTotal" text="TOTAL BIAYA" prefWidth="150"/>
                        <TableColumn fx:id="colStatus" text="STATUS BAYAR" prefWidth="150"/>
                        <TableColumn fx:id="colMetode" text="METODE" prefWidth="120"/>
                        <TableColumn fx:id="colTanggal" text="TANGGAL" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
