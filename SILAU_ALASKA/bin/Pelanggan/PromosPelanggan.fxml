<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Pelanggan.PromosPelangganController"
            fitToWidth="true"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">
    <content>
        <VBox spacing="24" style="-fx-background-color:#f4f6f5;">
            <padding><Insets top="28" right="35" bottom="28" left="35"/></padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Promo Laundry"
                           style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <Label text="Kode promo aktif yang bisa kamu gunakan saat checkout"
                           style="-fx-font-size:13; -fx-text-fill:#6b7280;"/>
                </VBox>
            </HBox>

            <FlowPane fx:id="flowPromo"
                      hgap="20" vgap="20"
                      prefWrapLength="900"
                      style="-fx-background-color:transparent;"/>

            <VBox fx:id="emptyState" alignment="CENTER" spacing="12"
                  visible="false" managed="false"
                  style="-fx-background-color:white; -fx-background-radius:15;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);
                         -fx-padding:60;">
                <Label text="🎟️" style="-fx-font-size:48;"/>
                <Label text="Belum Ada Promo Aktif"
                       style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                <Label text="Pantau terus ya, promo menarik akan segera hadir!"
                       style="-fx-font-size:13; -fx-text-fill:#9ca3af;"/>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
