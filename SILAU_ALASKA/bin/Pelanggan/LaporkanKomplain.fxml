<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Pelanggan.LaporkanKomplainController"
            fitToWidth="true"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">
    <content>
        <VBox spacing="20" style="-fx-background-color:#f4f6f5;">
            <padding><Insets top="28" right="35" bottom="28" left="35"/></padding>

            <!-- Header -->
            <VBox spacing="4">
                <Label text="Laporkan Komplain" style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                <Label text="Sampaikan keluhan Anda kepada kami" style="-fx-font-size:12; -fx-text-fill:#9ca3af;"/>
            </VBox>

            <!-- Form Card -->
            <VBox spacing="16" maxWidth="650"
                  style="-fx-background-color:white; -fx-background-radius:15;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                <Label text="Form Komplain" style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#111827;"/>

                <!-- Pilih Pesanan Terkait -->
                <VBox spacing="6">
                    <Label text="Pilih Pesanan Terkait" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                    <ComboBox fx:id="cbPesanan" prefWidth="600" promptText="-- Pilih Pesanan --"
                              style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:4;"/>
                </VBox>

                <!-- Jenis Komplain -->
                <VBox spacing="6">
                    <Label text="Jenis Komplain" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                    <ComboBox fx:id="cbJenisKomplain" prefWidth="600" promptText="-- Pilih Jenis Komplain --"
                              style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:4;"/>
                </VBox>

                <!-- Deskripsi Masalah -->
                <VBox spacing="6">
                    <Label text="Deskripsi Masalah" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                    <TextArea fx:id="txtDeskripsi" prefHeight="100" promptText="Jelaskan masalah Anda secara detail..."
                              style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:6;"/>
                </VBox>

                <!-- Button -->
                <Button text="Kirim Komplain" onAction="#kirimKomplain" maxWidth="Infinity" prefHeight="44"
                        style="-fx-background-color:#1e5af6; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14; -fx-background-radius:8; -fx-cursor:hand;"/>

            </VBox>

            <!-- Riwayat Komplain Saya Section -->
            <VBox spacing="14" maxWidth="650">
                <Label text="Riwayat Komplain Saya" style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#111827;"/>

                <!-- Container of dynamic complaint cards -->
                <VBox fx:id="vboxRiwayat" spacing="12">
                    <!-- Cards will be added here dynamically from controller -->
                </VBox>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
