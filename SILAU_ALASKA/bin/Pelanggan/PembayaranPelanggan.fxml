<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/9" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Pelanggan.PembayaranPelangganController"
            fitToWidth="true"
            style="-fx-background:#f4f6f5; -fx-background-color:#f4f6f5;">
    <content>
        <HBox spacing="30" style="-fx-background-color:#f4f6f5;">
            <padding><Insets top="28" right="35" bottom="28" left="35"/></padding>

            <!-- Bagian Kiri: Form Pembayaran -->
            <VBox spacing="20" prefWidth="550">
                <VBox spacing="4">
                    <Label text="Menu Pembayaran" style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <Label text="Selesaikan pembayaran pesanan Anda dengan promo &amp; diskon" style="-fx-font-size:12; -fx-text-fill:#9ca3af;"/>
                </VBox>

                <!-- Form Card -->
                <VBox spacing="16" style="-fx-background-color:white; -fx-background-radius:15; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                    <!-- Pilih Pesanan -->
                    <VBox spacing="6">
                        <Label text="Pilih Pesanan Terkait" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <ComboBox fx:id="cbPesanan" prefWidth="500" promptText="-- Pilih Pesanan --"
                                  style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:4;"/>
                    </VBox>

                    <!-- Pilih Promo/Diskon -->
                    <VBox spacing="6">
                        <Label text="Pilih Promo / Diskon" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <ComboBox fx:id="cbPromo" prefWidth="500" promptText="-- Pilih Promo (Opsional) --"
                                  style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:4;"/>
                    </VBox>

                    <!-- Metode Pembayaran -->
                    <VBox spacing="6">
                        <Label text="Metode Pembayaran" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <ComboBox fx:id="cbMetode" prefWidth="500" promptText="-- Pilih Metode Pembayaran --"
                                  style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:4;"/>
                    </VBox>

                    <Separator/>

                    <!-- Summary Area -->
                    <VBox spacing="10" style="-fx-background-color:#f8fafc; -fx-background-radius:10; -fx-padding:14;">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Awal:" style="-fx-font-size:13; -fx-text-fill:#64748b;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblTotalAwal" text="Rp 0" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#334155;"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT">
                            <Label text="Diskon Promo:" style="-fx-font-size:13; -fx-text-fill:#16a34a;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblDiskon" text="-Rp 0" style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#16a34a;"/>
                        </HBox>

                        <Separator style="-fx-padding:4 0;"/>

                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Bayar:" style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#1e293b;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblTotalBayar" text="Rp 0" style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#6495ed;"/>
                        </HBox>
                    </VBox>

                    <!-- Bayar Button -->
                    <Button text="Bayar Sekarang" onAction="#prosesBayar" maxWidth="Infinity" prefHeight="44"
                            style="-fx-background-color:#6495ed; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14; -fx-background-radius:8; -fx-cursor:hand;"/>

                </VBox>
            </VBox>

            <!-- Bagian Kanan: Riwayat Pembayaran (Transaksi) -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <VBox spacing="4">
                    <Label text="Riwayat Transaksi Saya" style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <Label text="Catatan pembayaran &amp; status invoice transaksi Anda" style="-fx-font-size:12; -fx-text-fill:#9ca3af;"/>
                </VBox>

                <VBox spacing="0" style="-fx-background-color:white; -fx-background-radius:15; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,3);">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <TableView fx:id="tabelTransaksi" prefHeight="480" style="-fx-background-color:transparent;">
                        <columns>
                            <TableColumn fx:id="colId" text="ID TX" prefWidth="90"/>
                            <TableColumn fx:id="colPesanan" text="PESANAN" prefWidth="90"/>
                            <TableColumn fx:id="colTotal" text="TOTAL BAYAR" prefWidth="120"/>
                            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="110"/>
                            <TableColumn fx:id="colMetode" text="METODE" prefWidth="110"/>
                            <TableColumn fx:id="colTanggal" text="TANGGAL" prefWidth="110"/>
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    </TableView>
                </VBox>
            </VBox>

        </HBox>
    </content>
</ScrollPane>
