<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="12" prefWidth="380"
      style="-fx-background-color:white;"
      xmlns="http://javafx.com/javafx/9" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Pelanggan.EditProfilPelangganController">

    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

    <Label text="Edit Profil">
        <font><Font name="System Bold" size="18.0"/></font>
    </Label>

    <Label text="Perbarui data akun Anda" style="-fx-text-fill:#6b7280; -fx-font-size:11;"/>

    <Separator/>

    <StackPane>
        <Circle fill="#e5e7eb" radius="24"/>
        <Label fx:id="lblInisialEdit" text="A" style="-fx-text-fill:#374151; -fx-font-weight:bold; -fx-font-size:16;"/>
    </StackPane>

    <Label fx:id="lblNama" text="Nama Pelanggan" style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
    <Label text="Nama tidak dapat diubah karena digunakan sebagai identitas pesanan Anda."
           style="-fx-text-fill:#9ca3af; -fx-font-size:10;" wrapText="true" textAlignment="CENTER"/>

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="Nomor Telepon" style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;"/>
        <TextField fx:id="txtTelepon" prefWidth="330" promptText="Masukkan nomor telepon"
                   style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:6;"/>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="Email" style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;"/>
        <TextField fx:id="txtEmail" prefWidth="330" promptText="Masukkan email"
                   style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:6;"/>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="Alamat" style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;"/>
        <TextField fx:id="txtAlamat" prefWidth="330" promptText="Masukkan alamat"
                   style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:6;"/>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="Username" style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;"/>
        <TextField fx:id="txtUsername" prefWidth="330" promptText="Masukkan username"
                   style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:6;"/>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="Password Baru (opsional)" style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;"/>
        <PasswordField fx:id="txtPasswordBaru" prefWidth="330" promptText="Kosongkan jika tidak ingin mengubah password"
                       style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:6;"/>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
        <Label text="Konfirmasi Password Baru" style="-fx-font-size:12; -fx-text-fill:#374151; -fx-font-weight:bold;"/>
        <PasswordField fx:id="txtKonfirmasiPassword" prefWidth="330" promptText="Ulangi password baru"
                       style="-fx-background-color:white; -fx-border-color:#e2e8f0; -fx-border-radius:8; -fx-background-radius:8; -fx-padding:6;"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Batal" onAction="#batal" prefWidth="160" prefHeight="38"
                style="-fx-background-color:#f1f5f9; -fx-text-fill:#374151; -fx-font-size:13;
                       -fx-background-radius:8; -fx-cursor:hand;"/>
        <Button text="Simpan Perubahan" onAction="#simpan" prefWidth="160" prefHeight="38"
                style="-fx-background-color:#6495ed; -fx-text-fill:white; -fx-font-size:13;
                       -fx-font-weight:bold; -fx-background-radius:8; -fx-cursor:hand;"/>
    </HBox>

</VBox>